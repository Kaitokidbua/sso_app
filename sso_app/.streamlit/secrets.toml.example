# คัดลอกไฟล์นี้เป็น .streamlit/secrets.toml แล้วใส่ค่าจริง
# บน Streamlit Cloud: เอาเนื้อหานี้ไปวางใน Settings -> Secrets

# ---- MongoDB Atlas (เก็บ user / profile ของบัว) ----
[mongo]
uri = "mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority"
database = "sso_app"

# ---- Snowflake (เก็บข้อมูล analytics ของ Dashboard) ----
[snowflake]
account   = "xxxxxxxx.region.aws"
user      = "YOUR_USER"
password  = "YOUR_PASSWORD"
warehouse = "COMPUTE_WH"
database  = "SSO_DB"
schema    = "PUBLIC"
role      = "ACCOUNTADMIN"

# ---- chatbot AI (หน้าเพื่อน) -- ต้องเป็น key ระดับบนสุด ----
MONGODB_URI = "mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority"
AI_PROVIDER = "gemini"
# ขอ Gemini API key ฟรีที่ aistudio.google.com -> Get API key
GEMINI_API_KEY = "ใส่ Gemini API key ตรงนี้"
GEMINI_MODEL = "gemini-2.0-flash"
